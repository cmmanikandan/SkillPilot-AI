{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile, onboarding preferences, and gamification stats.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "role": { "type": "string", "enum": ["student", "professional", "hobbyist"] },
        "skills": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "industry": { "type": "string" },
        "goals": { "type": "string" },
        "xp": { "type": "integer" },
        "level": { "type": "integer" },
        "streak": { "type": "integer" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Curriculum": {
      "title": "Learning Curriculum",
      "description": "A personalized learning plan generated by AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string", "description": "Optional ID for extra courses" },
        "title": { "type": "string" },
        "isExtra": { "type": "boolean" },
        "days": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "day": { "type": "integer" },
              "topic": { "type": "string" },
              "tasks": { "type": "array", "items": { "type": "string" } },
              "resources": { 
                "type": "array", 
                "items": { 
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "url": { "type": "string" }
                  }
                } 
              },
              "assignment": { "type": "string" },
              "difficulty": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "CurriculumProgress": {
      "title": "Curriculum Progress",
      "description": "Tracks completion status per curriculum.",
      "type": "object",
      "properties": {
        "completedDays": { "type": "array", "items": { "type": "integer" } },
        "currentDay": { "type": "integer" },
        "assignments": { "type": "object" },
        "resourceVisits": { "type": "object" },
        "lastCompletedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Progress": {
      "title": "User Progress",
      "description": "Tracks completion status of curriculum days.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "completedDays": { "type": "array", "items": { "type": "integer" } },
        "currentDay": { "type": "integer" },
        "lastCompletedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Friend": {
      "title": "Friendship",
      "description": "Represents a friendship between two users.",
      "type": "object",
      "properties": {
        "userId1": { "type": "string" },
        "userId2": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId1", "userId2", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and stats."
    },
    "/curriculums/{curriculumId}": {
      "schema": "Curriculum",
      "description": "Generated learning plans."
    },
    "/curriculumProgress/{curriculumId}": {
      "schema": "CurriculumProgress",
      "description": "Progress tracking for a specific curriculum."
    },
    "/progress/{userId}": {
      "schema": "Progress",
      "description": "User learning progress."
    },
    "/friends/{friendId}": {
      "schema": "Friend",
      "description": "User friendships."
    }
  }
}
